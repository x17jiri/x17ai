{
	"seq_len": 16384,
	"D_MODEL": 2048,
	"N_HEADS": 64,
	"HEAD_DIM": 32,
	"SPARSE_FAN_IN": 512,
	"F_WIDTH": 4096,
	"WINDOW_SIZE": 256,
	"L2_NORM_EPS": 1e-30,
	"V_SCALE_FIX": 1.5,

	"QK_SEGMENT_SIZE": { "type": "usize", "expr": "N_HEADS * HEAD_DIM" },
	"VG_SEGMENT_SIZE": { "type": "usize", "expr": "N_HEADS * HEAD_DIM" },
	"QKVG_ROWS":       { "type": "usize", "expr": "2*QK_SEGMENT_SIZE + 2*VG_SEGMENT_SIZE" },
}
